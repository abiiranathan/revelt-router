{
    "compilerOptions": {
        "target": "ES2020",
        "lib": [
            "ES2020",
            "DOM",
            "DOM.Iterable"
        ],
        "module": "ESNext",
        "moduleResolution": "bundler",
        "jsx": "react-jsx",
        "strict": true,
        "declaration": true,
        "declarationMap": true,
        "emitDeclarationOnly": true,
        "outDir": "dist",
        "verbatimModuleSyntax": true,
        "types": [
            "@testing-library/jest-dom"
        ]
    },
    "include": [
        "src"
    ],
    "exclude": [
        "src/test",
        "node_modules",
        "vite.config.ts"
    ]
}